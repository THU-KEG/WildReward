# =============================================================================
# Reward Model Deployment Configuration
# =============================================================================
# Copy this file to .env and update with your settings

# =============================================================================
# Common Settings
# =============================================================================

# Path to your trained reward model checkpoint
# This is REQUIRED - update it to point to your model
MODEL_PATH=/path/to/your/model

# Batch size for inference (adjust based on GPU memory)
BATCH_SIZE=16

# Enable FP16 mixed precision for faster inference
USE_FP16=true

# Maximum sequence length for tokenization
MAX_LENGTH=4096


# =============================================================================
# Worker Settings (for each worker instance)
# =============================================================================

# GPU device ID for this worker (0, 1, 2, etc.)
CUDA_VISIBLE_DEVICES=0

# Port for this worker instance
PORT=8004


# =============================================================================
# Router Settings
# =============================================================================

# Comma-separated list of backend worker URLs
BACKENDS=http://localhost:8004/get_reward,http://localhost:8005/get_reward,http://localhost:8006/get_reward,http://localhost:8007/get_reward

# Router port
ROUTER_PORT=9000

# Request timeout in seconds
ROUTER_TIMEOUT=200


# =============================================================================
# Deployment Script Settings
# =============================================================================

# Number of worker instances to spawn
NUM_WORKERS=4

# Starting GPU ID for workers (e.g., 0 means GPUs 0,1,2,3)
START_GPU_ID=0

# Starting port for workers (e.g., 8000 means ports 8000,8001,8002,8003)
WORKER_START_PORT=8000
